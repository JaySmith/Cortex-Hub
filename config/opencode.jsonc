{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "glm-4.7:cloud": { "name": "GLM-4.7 Cloud" },
        "llama3.2:latest": { "name": "Llama 3.2" }
      }
    }
  },
  "mcp": {
    "magrathea": {
      "type": "remote",
      "url": "http://192.168.86.10:4096/mcp",
      "enabled": true
    }
  }
}
